rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    /* ============================= */
    /* helpers                       */
    /* ============================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(db)/documents/users/$(uid));
    }

    function userRole(uid) {
      return isSignedIn() ? userDoc(uid).data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && userRole(request.auth.uid) == 'admin';
    }

    function isOwnerDoctor(doctorId) {
      return isSignedIn()
        && userRole(request.auth.uid) == 'doctor'
        && userDoc(request.auth.uid).data.doctorId == doctorId;
    }

    function isDoctorSubscriptionActive(uid) {
      let u = get(/databases/$(db)/documents/users/$(uid)).data;
      return u.subscriptionActive == true
        && u.subscriptionEnd != null
        && u.subscriptionEnd.toMillis() > request.time.toMillis();
    }
    function hasActiveSecretarySession(doctorId) {
  return isSignedIn()
    && userDoc(request.auth.uid).data.role == 'secretary'
    && userDoc(request.auth.uid).data.activeSecretaryDoctorId == doctorId;
}
    /* ============================= */
    /* users (SOURCE OF TRUTH)       */
    /* ============================= */

    match /users/{uid} {

      
allow get: if isSignedIn()
  && (request.auth.uid == uid || isAdmin());


      allow list: if isAdmin();

      allow create: if isSignedIn()
        && request.auth.uid == uid;

      // المستخدم يعدّل بياناته فقط (ليس الاشتراك)
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'displayName',
          'photoUrl',
          'phone',
          'fcmTokens',
          'lastLoginAt',
          'subscriptionNotificationSeen',
          'activeSecretaryDoctorId' // ✅ أضف هذا

        ])

      // ✅ الأدمن فقط يعدّل الاشتراك / الدور
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }
/* ============================= */
/* patients                      */
/* ============================= */

match /patients/{uid} {

  // ✅ السماح بالإنشاء الأولي
  allow create: if isSignedIn()
    && request.auth.uid == uid
    && (
      // الحالة 1: role موجود فعلًا
      userDoc(request.auth.uid).data.role == 'patient'
      ||
      // الحالة 2: role يُنشأ الآن في users (first-time signup)
      !exists(/databases/$(db)/documents/patients/$(uid))
    );

  // ✅ المريض يقرأ ويعدّل بياناته فقط
  allow read, update: if isSignedIn()
    && request.auth.uid == uid;

  // ✅ الحذف للأدمن فقط
  allow delete: if isAdmin();
}
    /* ============================= */
    /* subscription_requests (INFO) */
    /* ============================= */

    match /subscription_requests/{id} {

      // الطبيب ينشئ فقط (إعلام)
      allow create: if isSignedIn()
        && userRole(request.auth.uid) == 'doctor';

      // الأدمن يقرأ
      allow read, update: if isAdmin();
    }
  /* ============================= */
    /* secretary_public_collection  */
    /* ============================= */   
match /secretary_codes_public/{id} {
  allow read: if true;

  allow create: if isSignedIn();

  allow update, delete: if isAdmin()
    || isOwnerDoctor(
      get(/databases/$(db)/documents/doctors/$(resource.data.doctorId)).id
    );
}
    /* ============================= */
    /* secretary_sessions            */
    /* ============================= */

 match /secretary_sessions/{id} {

  function codePath(doctorId, codeId) {
    return /databases/$(db)/documents/doctors/$(doctorId)/secretary_codes/$(codeId);
  }

  // قراءة document واحد
  allow get: if isSignedIn()
    && resource.data.secretaryUid == request.auth.uid;

  // ✅ FIX: السماح بالـ query
  allow list: if isSignedIn();

  allow create: if isSignedIn()
  && request.resource.data.secretaryUid == request.auth.uid
  && request.resource.data.status == 'active'
  && request.resource.data.doctorId is string
  && request.resource.data.codeId is string
  && exists(/databases/$(db)/documents/secretary_codes_public/$(request.resource.data.codeId))
  && get(/databases/$(db)/documents/secretary_codes_public/$(request.resource.data.codeId)).data.active == true;

  allow update: if isSignedIn()
    && resource.data.secretaryUid == request.auth.uid;

  // ❌ احذف هذا السطر بالكامل
  // allow list, delete: if false;
}
/* ============================= */
/* financial_transactions       */
/* ============================= */

match /financial_transactions/{id} {

  // ✅ الطبيب يرى معاملاته فقط
allow read: if
  isAdmin() // ✅ أهم سطر
  || (
    isSignedIn()
    && userRole(request.auth.uid) == 'doctor'
    && resource.data.doctorId == userDoc(request.auth.uid).data.doctorId
  );
  // ✅ الإنشاء عند check-in
  allow create: if
    isSignedIn()
    && (
      userRole(request.auth.uid) == 'doctor'
      || userRole(request.auth.uid) == 'secretary'
    );

  // ❌ لا تعديل ولا حذف (محاسبة)
allow delete: if isAdmin();
}
    /* ============================= */
    /* doctors (PROFILE ONLY)        */
    /* ============================= */

    match /doctors/{doctorId} {

      // ✅ القراءة مفتوحة
      allow get, list: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      // ✅ التعديل فقط مع اشتراك نشط
      allow update: if
        isAdmin()
        || (
          isOwnerDoctor(doctorId)
          && isDoctorSubscriptionActive(request.auth.uid)
        )
        || hasActiveSecretarySession(doctorId);
    }
/* ============================= */
/* doctors/secretary_codes       */
/* ============================= */
match /doctors/{doctorId}/secretary_codes/{codeId} {
  // ✅ السكريتير يستطيع قراءة الكود للتحقق
  allow get: if isSignedIn();
  // الطبيب فقط يرى القائمة
  allow list: if
    isAdmin()
    || isOwnerDoctor(doctorId);
  // إنشاء الكود
  allow create: if
    isOwnerDoctor(doctorId)
    && request.resource.data.code == codeId
    && request.resource.data.doctorId == doctorId
    && request.resource.data.active == true;
  // تعديل الكود
  allow update: if
    isAdmin()
    || isOwnerDoctor(doctorId);
  // حذف
  allow delete: if
    isAdmin()
    || isOwnerDoctor(doctorId);
}
/* ============================= */
/* doctor_slots                  */
/* ============================= */

match /doctor_slots/{slotId} {

  // القراءة
  allow get, list: if isSignedIn();

  // إنشاء الـ slot عند الحجز
  allow create: if
    isSignedIn()
    && request.resource.data.patientId == request.auth.uid;

  // حذف/تحديث الـ slot عند الإلغاء
 allow update, delete: if
  isAdmin() // ✅ أضف هذا
  || (
    isSignedIn()
    && (
      resource.data.patientId == request.auth.uid

      || (
        userRole(request.auth.uid) == 'doctor'
        && userDoc(request.auth.uid).data.doctorId == resource.data.doctorId
      )

      || (
        userRole(request.auth.uid) == 'secretary'
        && userDoc(request.auth.uid).data.activeSecretaryDoctorId
             == resource.data.doctorId
      )
    )
  );
}
/* ============================= */
/* appointments                  */
/* ============================= */

match /appointments/{id} {

  /* ---------- القراءة ---------- */
  allow get, list: if
    isAdmin()

    // ✅ الطبيب يرى مواعيده فقط
    || (
      isSignedIn()
      && userRole(request.auth.uid) == 'doctor'
       && userDoc(request.auth.uid).data.doctorId == resource.data.doctorId
    )

    // ✅ المريض يرى مواعيده فقط
    || (
      isSignedIn()
      && resource.data.patientId == request.auth.uid
    )

    // ✅ السكرتير يرى مواعيد الطبيب الذي يخدمه
    || hasActiveSecretarySession(resource.data.doctorId);

  /* ---------- الإنشاء ---------- */
  allow create: if
    isAdmin()

    // ✅ المريض يحجز لنفسه
    || (
      isSignedIn()
      && request.resource.data.patientId == request.auth.uid
    )

    // ✅ الطبيب (إضافة يدوية باشتراك نشط)
    || (
      isSignedIn()
      && userRole(request.auth.uid) == 'doctor'
      && isDoctorSubscriptionActive(request.auth.uid)
    )

    // ✅ السكرتير
    || hasActiveSecretarySession(request.resource.data.doctorId);

/* ---------- التعديل ---------- */
allow update: if
  isAdmin()

  // ✅ الطبيب يعدّل مواعيده
  || (
    isSignedIn()
    && userRole(request.auth.uid) == 'doctor'
    && userDoc(request.auth.uid).data.doctorId == resource.data.doctorId
  )
  // ✅ المريض يلغي موعده أو يزيل الإشعار فقط
|| (
  isSignedIn()
  && resource.data.patientId == request.auth.uid
    && (
      // ✅ إلغاء الموعد
      request.resource.data.status == 'canceled'

      // ✅ إزالة patientUpdate فقط
      || request.resource.data.diff(resource.data)
           .changedKeys()
           .hasOnly(['patientUpdate'])
    )
)
  // ✅ السكرتير
  || hasActiveSecretarySession(resource.data.doctorId);

/* ---------- الحذف ---------- */
allow delete: if
  isAdmin()

  // ✅ المريض يحذف موعده الملغى
  || (
    isSignedIn()
    && resource.data.patientId == request.auth.uid
    && resource.data.status == 'canceled'
  )

  // ✅ الطبيب يحذف مواعيده الملغاة فقط
  || (
    isSignedIn()
    && userRole(request.auth.uid) == 'doctor'
    && userDoc(request.auth.uid).data.doctorId == resource.data.doctorId
    && resource.data.status == 'canceled'
  )

  // ✅ السكرتير يحذف مواعيد الطبيب الذي يخدمه (إذا كانت ملغاة)
  || (
    isSignedIn()
    && userRole(request.auth.uid) == 'secretary'
    && userDoc(request.auth.uid).data.activeSecretaryDoctorId == resource.data.doctorId
    && resource.data.status == 'canceled'
  );
}
    /* ============================= */
    /* doctor_days                   */
    /* ============================= */

    match /doctor_days/{doctorId} {

      allow get, list: if isSignedIn();

      allow create, update: if
        isAdmin()
        || (
          isOwnerDoctor(doctorId)
          && isDoctorSubscriptionActive(request.auth.uid)
        )
        || hasActiveSecretarySession(doctorId);

      allow delete: if isAdmin();
    }
/* ============================= */
/* doctor_days/days (SUBCOLL)    */
/* ============================= */

match /doctor_days/{doctorId}/days/{dayId} {

  // ✅ القراءة مسموحة (حتى لو لا توجد أيام)
  allow get, list: if isSignedIn();

  // ✅ التعديل فقط باشتراك نشط
  allow create, update: if
    isAdmin()
    || (
      isOwnerDoctor(doctorId)
      && isDoctorSubscriptionActive(request.auth.uid)
    )
    || hasActiveSecretarySession(doctorId);

  allow delete: if isAdmin();
}
    /* ============================= */
    /* doctor_days_off               */
    /* ============================= */

    match /doctor_days_off/{id} {

      allow get, list: if isSignedIn();

      allow create, update: if
        isAdmin()
        || (
          isOwnerDoctor(request.resource.data.doctorId)
          && isDoctorSubscriptionActive(request.auth.uid)
        )
        || hasActiveSecretarySession(request.resource.data.doctorId);

     allow delete: if
  isSignedIn()
  && (
    isAdmin()
    || isOwnerDoctor(resource.data.doctorId)
    || hasActiveSecretarySession(resource.data.doctorId)
  );
    }



   /* ============================= */
/* reports                       */
/* ============================= */

match /reports/{id} {

  // ✅ Admin يرى الجميع + Doctor يرى فقط بلاغاته
  allow get, list: if isAdmin()
    || (
      isSignedIn() &&
      resource.data.senderId == request.auth.uid
    );

  // ✅ أي مستخدم يسجل بلاغ لنفسه
  allow create: if isSignedIn()
    && request.resource.data.senderId == request.auth.uid;

  // ✅ فقط Admin يعدل (الرد + الحالة)
 allow update: if isAdmin()
  || (
    isSignedIn()
    && request.auth.uid == resource.data.senderId
    && request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['replySeen'])  // ✅ يسمح فقط بهذا الحقل
  );

  // ✅ فقط Admin يحذف
  allow delete: if isAdmin();
}

    /* ============================= */
    /* read-only                     */
    /* ============================= */

    match /governorates/{id} {
      allow get, list: if true;
    }

    match /specialties/{id} {
      allow get, list: if true;
    }
match /secretaries/{uid} {
  allow create, read: if isSignedIn()
    && request.auth.uid == uid;

  allow update: if isSignedIn()
    && request.auth.uid == uid;

  allow delete: if isAdmin();
}
    /* ============================= */
    /* default deny                  */
    /* ============================= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}