rules_version = '2';
service cloud.firestore {
match /databases/{db}/documents {

/* ============================= */
/* basic helpers                 */
/* ============================= */

function isSignedIn() {
  return request.auth != null;
}

function userDoc(uid) {
  return get(/databases/$(db)/documents/users/$(uid));
}

function userRole(uid) {
  return isSignedIn() ? userDoc(uid).data.role : null;
}

function isAdmin() {
  return isSignedIn() && userRole(request.auth.uid) == 'admin';
}

function isPatient(uid) {
  return userRole(uid) == 'patient';
}

function isOwnerDoctorDoc(doctorId) {
  return isSignedIn()
    && userRole(request.auth.uid) == 'doctor'
    && userDoc(request.auth.uid).data.doctorId == doctorId;
}

/* ============================= */
/* secretary session check       */
/* ============================= */

function hasActiveSecretarySession(doctorId) {

  let path = /databases/$(db)/documents/secretary_sessions/$(request.auth.uid + "_" + doctorId);

  return isSignedIn()
    && exists(path)
    && get(path).data.active == true
    && get(path).data.secretaryUid == request.auth.uid
    && get(path).data.doctorId == doctorId;
}

/* ============================= */
/* users                         */
/* ============================= */

match /users/{uid} {

allow get: if isSignedIn() && (
      request.auth.uid == uid
      || isAdmin()
);

allow list: if isAdmin();

allow create: if isSignedIn() && request.auth.uid == uid;

allow update: if isSignedIn()
  && request.auth.uid == uid
  && request.resource.data.keys().hasOnly([
    'displayName',
    'photoUrl',
    'phone',
    'fcmTokens',
    'lastLoginAt'
]);

allow update: if isAdmin()
  && request.resource.data.diff(resource.data).changedKeys().hasOnly([
    'subscriptionActive',
    'subscriptionPlan',
    'subscriptionEnd',
    'subscriptionUpdatedAt'
]);

allow delete: if isAdmin();
}

/* ============================= */
/* secretary_sessions            */
/* ============================= */

match /secretary_sessions/{sessionId} {

allow get: if isSignedIn()
  && resource.data.secretaryUid == request.auth.uid;

allow list: if false;

allow create: if isSignedIn()
  && request.resource.data.secretaryUid == request.auth.uid
  && request.resource.data.active == true
  && exists(/databases/$(db)/documents/secretary_codes_public/$(request.resource.data.codeId));

allow update: if isSignedIn()
  && resource.data.secretaryUid == request.auth.uid;

allow delete: if false;
}

/* ============================= */
/* appointments                  */
/* ============================= */

function isValidAppointmentStatus(s) {
return s == 'pending'
  || s == 'confirmed'
  || s == 'canceled'
  || s == 'cancelled'
  || s == 'checked_in'
  || s == 'no_show';
}

function allowedStatusTransition(prev, next) {
return
  ((prev == 'pending') && (next == 'confirmed' || next == 'canceled' || next == 'cancelled'))
  ||
  ((prev == 'confirmed') && (next == 'checked_in' || next == 'no_show' || next == 'canceled' || next == 'cancelled'))
  ||
  (prev == next);
}

match /appointments/{appointmentId} {

allow get, list: if isAdmin()
  || (isSignedIn() && (
      resource.data.patientId == request.auth.uid
      || isOwnerDoctorDoc(resource.data.doctorId)
      || hasActiveSecretarySession(resource.data.doctorId)
));

allow create: if isSignedIn()
  && request.resource.data.doctorId is string
  && request.resource.data.patientId is string
  && isValidAppointmentStatus(request.resource.data.status)
  && (
      (isPatient(request.auth.uid)
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.status == 'pending')
      ||
      isOwnerDoctorDoc(request.resource.data.doctorId)
      ||
      hasActiveSecretarySession(request.resource.data.doctorId)
);

allow update: if isSignedIn()
  && request.resource.data.doctorId == resource.data.doctorId
  && request.resource.data.patientId == resource.data.patientId
  && isValidAppointmentStatus(request.resource.data.status)
  && allowedStatusTransition(resource.data.status, request.resource.data.status)
  && (
      isAdmin()
      || isOwnerDoctorDoc(resource.data.doctorId)
      || hasActiveSecretarySession(resource.data.doctorId)
      || (
        request.auth.uid == resource.data.patientId
        && (request.resource.data.status == 'canceled' || request.resource.data.status == 'cancelled')
));

/* السكرتير يمكنه الحذف */

allow delete: if isAdmin()
  || isOwnerDoctorDoc(resource.data.doctorId)
  || hasActiveSecretarySession(resource.data.doctorId);
}

/* ============================= */
/* doctors                       */
/* ============================= */

match /doctors/{doctorId} {

allow get: if isSignedIn()
  || isAdmin()
  || isOwnerDoctorDoc(doctorId)
  || hasActiveSecretarySession(doctorId);

allow list: if isSignedIn();

/* منع السكرتير من تعديل إعدادات الطبيب */

allow update: if isAdmin()
  || isOwnerDoctorDoc(doctorId)
  || (
      hasActiveSecretarySession(doctorId)
      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'slotDuration',
        'schedule',
        'workingDays',
        'startTime',
        'endTime'
      ])
  );

/* ============================= */
/* secretary codes               */
/* ============================= */

match /secretary_codes/{codeId} {

allow get, list: if isAdmin()
  || isOwnerDoctorDoc(doctorId);

allow create, update, delete: if isAdmin()
  || isOwnerDoctorDoc(doctorId);
}

}

/* ============================= */
/* secretary_codes_public        */
/* ============================= */

match /secretary_codes_public/{codeId} {

allow get, list: if request.auth != null;

allow create: if request.auth != null
  && userRole(request.auth.uid) == "doctor";

allow update, delete: if request.auth != null
  && (
      userRole(request.auth.uid) == "admin"
      ||
      resource.data.doctorId ==
      userDoc(request.auth.uid).data.doctorId
);
}

/* ============================= */
/* doctor_slots                  */
/* ============================= */

match /doctor_slots/{slotId} {

/* ============================= */
/* القراءة                       */
/* ============================= */

allow get, list: if isSignedIn();

/* ============================= */
/* الإنشاء (الحجز)               */
/* ============================= */

allow create: if isSignedIn()
  && request.resource.data.doctorId is string
  && request.resource.data.date is string
  && request.resource.data.time is string
  && request.resource.data.taken == true;

/* ============================= */
/* التحديث                       */
/* ============================= */


allow update: if isSignedIn()
  && (
       isAdmin()
       || isOwnerDoctorDoc(resource.data.doctorId)
       || hasActiveSecretarySession(resource.data.doctorId)
       || (
            // المريض يحجز slot (taken: false → true)
            request.auth.uid == resource.data.patientId
            && request.resource.data.taken == true
            && resource.data.taken != true
          )
       || (
            // NEW ✅ المريض يلغي slot (taken: true → false)
            request.auth.uid == resource.data.patientId
            && request.resource.data.taken == false
            && resource.data.taken == true
          )
     );

/* ============================= */
/* الحذف                         */
/* ============================= */

allow delete: if isAdmin()
  || isOwnerDoctorDoc(resource.data.doctorId)
  || hasActiveSecretarySession(resource.data.doctorId);
}
/* ============================= */
/* doctor_days                   */
/* ============================= */

match /doctor_days/{doctorId} {

allow get, list: if isSignedIn()
  && (
      isAdmin()
      || isOwnerDoctorDoc(doctorId)
      || hasActiveSecretarySession(doctorId)
  );

allow create: if isSignedIn()
  && (
      isAdmin()
      || isOwnerDoctorDoc(doctorId)
      || hasActiveSecretarySession(doctorId)
  );

allow update: if isSignedIn()
  && (
      isAdmin()
      || isOwnerDoctorDoc(doctorId)
      || hasActiveSecretarySession(doctorId)
  );

allow delete: if isAdmin();

match /days/{dayId} {

allow get, list: if isSignedIn()
  && (
      isAdmin()
      || isOwnerDoctorDoc(doctorId)
      || hasActiveSecretarySession(doctorId)
  );

allow create: if isSignedIn()
  && (
      isAdmin()
      || isOwnerDoctorDoc(doctorId)
      || hasActiveSecretarySession(doctorId)
  );

allow update: if isSignedIn()
  && (
      isAdmin()
      || isOwnerDoctorDoc(doctorId)
      || hasActiveSecretarySession(doctorId)
  );

allow delete: if isAdmin();

}

}

/* ============================= */
/* doctor_days_off               */
/* ============================= */

match /doctor_days_off/{docId} {

allow get, list: if isSignedIn();

allow create, update: if isSignedIn()
  && (
      isOwnerDoctorDoc(request.resource.data.doctorId)
      || hasActiveSecretarySession(request.resource.data.doctorId)
      || isAdmin()
  );

allow delete: if isAdmin()
  || isOwnerDoctorDoc(resource.data.doctorId)
  || hasActiveSecretarySession(resource.data.doctorId);
}

/* ============================= */
/* reports                       */
/* ============================= */

function isValidReportStatus(s) {
return s == 'open'
  || s == 'in_progress'
  || s == 'resolved'
  || s == 'closed';
}

match /reports/{reportId} {

allow get, list: if isAdmin()
  || (isSignedIn() && resource.data.createdBy == request.auth.uid);

allow create: if isSignedIn()
  && request.resource.data.createdBy == request.auth.uid
  && isValidReportStatus(request.resource.data.status);

allow update: if isAdmin()
  && isValidReportStatus(request.resource.data.status);

allow delete: if isAdmin();
}

/* ============================= */
/* default deny                  */
/* ============================= */

match /{document=**} {
allow read, write: if false;
}

// ===== doctor_subscriptions/{doctorId} =====
match /doctor_subscriptions/{doctorId} {
  // القراءة لأي مستخدم مُسجّل؛ لا توجد بيانات حساسة هنا
  allow get, list: if request.auth != null;

  // الكتابة للأدمن فقط (يمكنك فتحها للطبيب أيضاً إن رغبت)
  allow create, update, delete: if request.auth != null
    && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role == "admin";
}

}
}