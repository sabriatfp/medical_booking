rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    /* ===================================================== */
    /*                    BASIC HELPERS                     */
    /* ===================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(db)/documents/users/$(uid));
    }

    function userRole(uid) {
      return isSignedIn() ? userDoc(uid).data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && userRole(request.auth.uid) == 'admin';
    }

    function isPatient(uid) {
      return userRole(uid) == 'patient';
    }

    function isOwnerDoctorDoc(doctorId) {
      return isSignedIn()
          && userRole(request.auth.uid) == 'doctor'
          && userDoc(request.auth.uid).data.doctorId == doctorId;
    }

    function hasActiveSecretarySession(doctorId) {
      let path = /databases/$(db)/documents/secretary_sessions/$(request.auth.uid + "_" + doctorId);
      return isSignedIn()
          && exists(path)
          && get(path).data.active == true
          && get(path).data.secretaryUid == request.auth.uid
          && get(path).data.doctorId == doctorId;
    }

    /* ===================================================== */
    /*                     USERS                              */
    /* ===================================================== */

    match /users/{uid} {
      allow get: if isSignedIn() &&
        (request.auth.uid == uid || isAdmin());

      allow list: if isAdmin();

      allow create: if isSignedIn() && request.auth.uid == uid;

      allow update: if isSignedIn() &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly([
          'displayName','photoUrl','phone','fcmTokens','lastLoginAt'
        ]);

      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data)
          .changedKeys()
          .hasOnly([
            'subscriptionActive','subscriptionPlan','subscriptionEnd','subscriptionUpdatedAt'
          ]);

      allow delete: if isAdmin();
    }

    /* ===================================================== */
    /*                   SECRETARY SESSIONS                  */
    /* ===================================================== */

    match /secretary_sessions/{sessionId} {
      allow get: if isSignedIn()
          && resource.data.secretaryUid == request.auth.uid;

      allow list: if false;

      allow create: if isSignedIn()
          && request.resource.data.secretaryUid == request.auth.uid
          && request.resource.data.active == true
          && exists(/databases/$(db)/documents/secretary_codes_public/$(request.resource.data.codeId));

      allow update: if isSignedIn()
          && resource.data.secretaryUid == request.auth.uid;

      allow delete: if false;
    }

    /* ===================================================== */
    /*                   DOCTOR SCHEDULE                     */
    /* ===================================================== */

    match /doctors/{doctorId} {

      allow get: if isSignedIn()
          && (
                isAdmin()
             || isOwnerDoctorDoc(doctorId)
             || hasActiveSecretarySession(doctorId)
          );

      allow list: if isSignedIn();

      allow update: if isSignedIn()
          && (
                isAdmin()
             || isOwnerDoctorDoc(doctorId)
             || (
                   hasActiveSecretarySession(doctorId)
                && request.resource.data.diff(resource.data)
                    .changedKeys()
                    .hasOnly([
                      'slotDuration','weeklyTemplate','weeks'
                    ])
             )
          );
    }

    /* ===================================================== */
    /*                  DOCTOR DAYS OFF                      */
    /* ===================================================== */

    match /doctor_days_off/{offId} {
      allow get, list: if isSignedIn();

      allow create, update: if isSignedIn()
          && (
               isOwnerDoctorDoc(request.resource.data.doctorId)
            || hasActiveSecretarySession(request.resource.data.doctorId)
            || isAdmin()
          );

      allow delete: if isSignedIn()
        && (
              isAdmin()
           || isOwnerDoctorDoc(resource.data.doctorId)
           || hasActiveSecretarySession(resource.data.doctorId)
        );
    }

    /* ===================================================== */
    /*                      DOCTOR SLOTS                     */
    /*             (حماية إنشاء Slot فقط من schedule)       */
    /* ===================================================== */

    match /doctor_slots/{slotId} {

      function validSlot(doctorId, date, time) {
        let doc = get(/databases/$(db)/documents/doctors/$(doctorId));

        // doctor document must exist
        if (!doc.exists()) return false;

        let allWeeks = doc.data.weeks;

        // weeks must be a list
        if !(allWeeks is list) return false;

        // Search inside weeks[x].days[y].slots[]
        return allWeeks.exists(w =>
          w.days.exists(d =>
            d.date == date
            && d.available == true
            && d.slots is list
            && d.slots.hasAny([time])
          )
        );
      }

      allow get, list: if isSignedIn();

      // إنشاء slot (يجب أن يطابق schedule)
      allow create: if isSignedIn()
        && request.resource.data.doctorId is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.taken == true
        && validSlot(
            request.resource.data.doctorId,
            request.resource.data.date,
            request.resource.data.time
        );

      // التحديث: فقط الطبيب / السكرتير يمكنهم تحرير slots
      allow update: if isSignedIn()
        && (
              isAdmin()
           || isOwnerDoctorDoc(resource.data.doctorId)
           || hasActiveSecretarySession(resource.data.doctorId)
           || (
                 // المريض يمكنه فقط حجز slot غير محجوز
                 request.resource.data.taken == true
              && resource.data.taken != true
           )
        );

      allow delete: if isSignedIn()
        && (
              isAdmin()
           || isOwnerDoctorDoc(resource.data.doctorId)
           || hasActiveSecretarySession(resource.data.doctorId)
        );
    }

    /* ===================================================== */
    /*                     APPOINTMENTS                      */
    /*        (يجب أن يكون مرتبطًا بـ slot صالح محجوز)       */
    /* ===================================================== */

    match /appointments/{appointmentId} {

      function slotDocument(slotId) {
        return get(/databases/$(db)/documents/doctor_slots/$(slotId));
      }

      allow get, list: if isAdmin()
        || (isSignedIn() && (
               resource.data.patientId == request.auth.uid
            || isOwnerDoctorDoc(resource.data.doctorId)
            || hasActiveSecretarySession(resource.data.doctorId)
        ));

      // إنشاء موعد
      allow create: if isSignedIn()
        && request.resource.data.doctorId is string
        && request.resource.data.patientId is string
        && request.resource.data.slotId is string
        && request.resource.data.status == "pending"
        // الموعد يجب أن يكون في المستقبل
        && request.resource.data.dateTime >= request.time
        // slot يجب أن يكون موجودًا + taken = true
        && slotDocument(request.resource.data.slotId).exists()
        && slotDocument(request.resource.data.slotId).data.taken == true
        // slot مرتبط بنفس doctorId
        && slotDocument(request.resource.data.slotId).data.doctorId
              == request.resource.data.doctorId
        // المريض لا يمكنه إنشاء موعد لشخص آخر
        && request.resource.data.patientId == request.auth.uid;

      // تحديث المواعيد (تأكيد - إلغاء - حضور - ...)
      allow update: if isSignedIn()
        && request.resource.data.doctorId == resource.data.doctorId
        && request.resource.data.patientId == resource.data.patientId
        && (
              isAdmin()
           || isOwnerDoctorDoc(resource.data.doctorId)
           || hasActiveSecretarySession(resource.data.doctorId)
           || (
                request.auth.uid == resource.data.patientId
             && (request.resource.data.status == "canceled"
              || request.resource.data.status == "cancelled")
           )
        );

      allow delete: if isSignedIn()
        && (
              isAdmin()
           || isOwnerDoctorDoc(resource.data.doctorId)
           || hasActiveSecretarySession(resource.data.doctorId)
        );
    }

    /* ===================================================== */
    /*                 DEFAULT DENY (VERY IMPORTANT)         */
    /* ===================================================== */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}